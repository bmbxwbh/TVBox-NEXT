<?xml version="1.0" encoding="utf-8"?>
<!-- TVBOX-NEXT: 大矩形卡片(Netflix 2025 风格,16:9 横向) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/vs_300"
    android:layout_height="@dimen/vs_170"
    android:background="@drawable/shape_big_card_bg"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:padding="@dimen/vs_2">

    <!-- 背景图/剧照(16:9) -->
    <ImageView
        android:id="@+id/ivCardThumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- 底部渐变遮罩 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/vs_80"
        android:layout_gravity="bottom"
        android:background="@drawable/shape_big_card_gradient" />

    <!-- 底部信息区:标题 + 信息标签 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingLeft="@dimen/vs_10"
        android:paddingRight="@dimen/vs_10"
        android:paddingBottom="@dimen/vs_8">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvCardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:shadowColor="@color/color_000000_90"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="4"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_22"
            android:textStyle="bold" />

        <!-- 信息标签行:年份 / 类型 / 评分 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_4"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCardYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/vs_6"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/color_B3B3B3"
                android:textSize="@dimen/ts_15" />

            <TextView
                android:id="@+id/tvCardType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/vs_6"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/color_B3B3B3"
                android:textSize="@dimen/ts_15" />

            <TextView
                android:id="@+id/tvCardRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/color_E50914"
                android:textSize="@dimen/ts_15"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
