<?xml version="1.0" encoding="utf-8"?>
<!-- TVBOX-NEXT: 首页横向滚动行(Netflix 风格,每行一个分类) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingTop="@dimen/vs_10"
    android:paddingBottom="@dimen/vs_10">

    <!-- 行标题 + 查看全部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/vs_50"
        android:paddingRight="@dimen/vs_50">

        <TextView
            android:id="@+id/tvRowTitle"
            android:layout_width="@dimen/vs_0"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_26"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRowMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingLeft="@dimen/vs_10"
            android:paddingTop="@dimen/vs_5"
            android:paddingRight="@dimen/vs_10"
            android:paddingBottom="@dimen/vs_5"
            android:text="查看全部 >"
            android:textColor="@color/color_B3B3B3"
            android:textSize="@dimen/ts_18" />
    </LinearLayout>

    <!-- 横向滚动卡片列表 -->
    <com.owen.tvrecyclerview.widget.TvRecyclerView
        android:id="@+id/mRowGridView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/vs_10"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="@dimen/vs_50"
        android:paddingRight="@dimen/vs_50"
        app:tv_horizontalSpacingWithMargins="@dimen/vs_15"
        app:tv_selectedItemIsCentered="false" />
</LinearLayout>
